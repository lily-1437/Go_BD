
# --- Sensitive Configuration Files ---
../config/db.php         # Database credentials (host, user, password)
.env                  # Environment variables
../config/config.php     # Any other config with secrets

# --- PHP Dependencies (if using Composer) ---
/vendor/

# --- XAMPP / Local Server Files ---
*.log
/logs/
# --- Uploaded Files by Users (not part of codebase) ---
uploads/
public/uploads/

# --- OS / System Files ---
.DS_Store             # macOS
Thumbs.db             # Windows
desktop.ini

# --- IDE / Editor Files ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Database Dumps (never commit these!) ---
*.dump

# --- Compiled / Cache Files ---
*.cache
/cache/